{
  "name": "slot-machine",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "update-api": "npx @openapitools/openapi-generator-cli generate -i http://localhost:5278/swagger/v1/swagger.json -g typescript-angular -o src/app/api-client --additional-properties=providedInRoot=true,supportsES6=true,useHttpClient=true,serviceSuffix=ApiService,withInterfaces=true",
    "lint": "node_modules/@angular/cli/bin/./ng.js lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.7",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.7",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/preferences": "^7.0.2",
    "@pixi/filter-alpha": "^6.5.10",
    "async-wait-until": "^2.0.30",
    "delay": "^6.0.0",
    "gsap": "^3.13.0",
    "howler": "^2.2.4",
    "lottie-web": "^5.13.0",
    "ngx-logger": "^5.0.12",
    "p-limit": "^7.2.0",
    "pixi.js": "^6.5.10",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.23.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.2",
    "@angular/build": "^20.3.2",
    "@angular/cli": "^20.3.2",
    "@angular/compiler-cli": "^20.3.0",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-onboarding": "^9.1.7",
    "@storybook/angular": "^9.1.7",
    "@storybook/testing-library": "^0.2.1",
    "@types/howler": "^2.2.12",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "20.3.0",
    "eslint": "^9.35.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "storybook": "^9.1.7",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.40.0"
